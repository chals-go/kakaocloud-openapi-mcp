{
  "workflows": [
    {
      "id": "create-vm",
      "name": "Create VM Instance",
      "nameKo": "VM 인스턴스 생성",
      "description": "카카오클라우드에서 VM 인스턴스를 생성하는 전체 흐름입니다. VPC, 서브넷, 보안 그룹, 키페어를 먼저 준비한 후 인스턴스를 생성합니다.",
      "keywords": ["vm 만들기", "vm 생성", "인스턴스 생성", "서버 만들기", "create vm", "create instance", "가상머신 만들기"],
      "steps": [
        {
          "order": 1,
          "action": "Get auth token",
          "actionKo": "인증 토큰 발급",
          "service": "iam",
          "endpoint": "",
          "method": "POST",
          "path": "https://iam.kakaocloud.com/identity/v3/auth/tokens",
          "note": "Access Key ID와 Secret Key로 토큰을 발급받습니다.",
          "outputUsedBy": [2, 3, 4, 5, 6]
        },
        {
          "order": 2,
          "action": "Create or get existing VPC",
          "actionKo": "VPC 생성 또는 기존 VPC 조회",
          "service": "bns-vpc",
          "endpoint": "create-vpc",
          "method": "POST",
          "path": "/vpcs",
          "note": "기존 VPC가 있으면 GET /vpcs로 조회하여 사용",
          "outputUsedBy": [3, 4]
        },
        {
          "order": 3,
          "action": "Create or get existing Subnet",
          "actionKo": "서브넷 생성 또는 기존 서브넷 조회",
          "service": "bns-vpc",
          "endpoint": "create-subnet",
          "method": "POST",
          "path": "/subnets",
          "note": "기존 서브넷이 있으면 GET /subnets로 조회. VPC ID 필요",
          "outputUsedBy": [6]
        },
        {
          "order": 4,
          "action": "Create Security Group",
          "actionKo": "보안 그룹 생성 및 규칙 추가",
          "service": "bns-vpc",
          "endpoint": "create-security-group",
          "method": "POST",
          "path": "/security-groups",
          "note": "SSH(22), HTTP(80) 등 필요한 포트를 인바운드 규칙으로 추가",
          "outputUsedBy": [6]
        },
        {
          "order": 5,
          "action": "Create Key Pair",
          "actionKo": "SSH 키페어 생성",
          "service": "bcs",
          "endpoint": "create-keypair",
          "method": "POST",
          "path": "/keypairs",
          "note": "이미 키페어가 있으면 생략 가능. 생성 시 private key를 반드시 저장",
          "outputUsedBy": [6]
        },
        {
          "order": 6,
          "action": "Create VM Instance",
          "actionKo": "VM 인스턴스 생성",
          "service": "bcs",
          "endpoint": "create-instance",
          "method": "POST",
          "path": "/instances",
          "note": "image_id는 GET /images로 사용 가능한 이미지를 먼저 조회. flavor는 GET /flavors로 조회"
        }
      ]
    },
    {
