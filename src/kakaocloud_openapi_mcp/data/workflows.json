        },
        {
          "order": 4,
          "action": "Create Security Group and Rules",
          "actionKo": "보안 그룹 및 규칙 생성",
          "service": "bns-vpc",
          "endpoint": "create-security-group",
          "method": "POST",
          "path": "/security-groups",
          "note": "보안 그룹 생성 후 POST /security-groups/{id}/rules로 규칙 추가"
