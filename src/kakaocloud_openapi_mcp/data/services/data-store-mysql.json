      "method": "POST",
      "path": "/db-instances",
      "summary": "MySQL 인스턴스 생성",
      "summaryKo": "MySQL 인스턴스 생성",
      "description": "관리형 MySQL 데이터베이스 인스턴스를 생성합니다.",
      "keywords": ["mysql 생성", "db 생성", "데이터베이스 생성", "create database"],
      "parameters": [],
      "requestBody": {
        "name": {"type": "string", "required": true, "description": "DB 인스턴스 이름"},
        "engine_version": {"type": "string", "required": true, "description": "MySQL 버전"},
        "flavor": {"type": "string", "required": true, "description": "인스턴스 타입"},
        "storage_size": {"type": "integer", "required": true, "description": "스토리지 크기 (GB)"},
        "vpc_id": {"type": "string", "required": true, "description": "VPC ID"},
        "subnet_id": {"type": "string", "required": true, "description": "서브넷 ID"},
        "master_username": {"type": "string", "required": true, "description": "마스터 사용자 이름"},
        "master_password": {"type": "string", "required": true, "description": "마스터 비밀번호"}
      },
      "exampleRequest": {
        "name": "my-mysql",
        "engine_version": "8.0",
        "flavor": "db.m2a.large",
        "storage_size": 50,
        "vpc_id": "VPC_ID",
        "subnet_id": "SUBNET_ID",
        "master_username": "admin",
        "master_password": "MyPassword123!"
      },
      "responses": {
        "201": {"description": "DB 인스턴스 생성 요청 수락"}
      }
    },
