{
  "id": "bns-load-balancer",
  "name": "Load Balancer",
  "nameKo": "로드 밸런서",
  "description": "카카오클라우드의 로드 밸런서 서비스. 트래픽을 여러 인스턴스에 분산합니다.",
  "baseUrl": "https://bns.kr-central-2.kakaocloud.com",
  "basePath": "/api/v1",
  "keywords": ["load balancer", "로드밸런서", "lb", "부하분산", "트래픽"],
  "dependencies": ["bns-vpc"],
  "endpoints": [
    {
      "id": "create-load-balancer",
      "method": "POST",
      "path": "/load-balancers",
      "summary": "로드 밸런서 생성",
      "summaryKo": "로드 밸런서 생성",
      "keywords": ["로드밸런서 생성", "lb 생성", "create load balancer"],
      "parameters": [],
      "requestBody": {
        "name": {"type": "string", "required": true, "description": "로드 밸런서 이름"},
        "vpc_id": {"type": "string", "required": true, "description": "VPC ID"},
        "subnet_id": {"type": "string", "required": true, "description": "서브넷 ID"},
        "type": {"type": "string", "required": false, "description": "로드 밸런서 타입 (application/network)"}
      },
      "responses": {
        "201": {"description": "로드 밸런서 생성 완료"}
      }
    },
    {
      "id": "list-load-balancers",
      "method": "GET",
      "path": "/load-balancers",
      "summary": "로드 밸런서 목록 조회",
      "summaryKo": "로드 밸런서 목록 조회",
      "keywords": ["로드밸런서 목록", "lb 목록", "list load balancers"],
      "parameters": [],
      "requestBody": null,
      "responses": {
        "200": {"description": "로드 밸런서 목록 반환"}
      }
    },
    {
      "id": "delete-load-balancer",
      "method": "DELETE",
      "path": "/load-balancers/:load_balancer_id",
      "summary": "로드 밸런서 삭제",
      "summaryKo": "로드 밸런서 삭제",
      "keywords": ["로드밸런서 삭제", "lb 삭제", "delete load balancer"],
      "parameters": [
        {"name": "load_balancer_id", "in": "path", "type": "string", "required": true, "description": "로드 밸런서 ID"}
      ],
      "requestBody": null,
      "responses": {
        "204": {"description": "로드 밸런서 삭제 완료"}
      }
    },
    {
      "id": "create-listener",
      "method": "POST",
      "path": "/load-balancers/:load_balancer_id/listeners",
      "summary": "리스너 생성",
      "summaryKo": "리스너 생성",
      "description": "로드 밸런서에 리스너를 추가합니다.",
      "keywords": ["리스너 생성", "listener", "포트 설정"],
      "parameters": [
        {"name": "load_balancer_id", "in": "path", "type": "string", "required": true, "description": "로드 밸런서 ID"}
      ],
      "requestBody": {
        "protocol": {"type": "string", "required": true, "description": "프로토콜 (HTTP/HTTPS/TCP)"},
        "port": {"type": "integer", "required": true, "description": "리스닝 포트"},
        "target_group_id": {"type": "string", "required": true, "description": "대상 그룹 ID"}
      },
      "responses": {
        "201": {"description": "리스너 생성 완료"}
      }
    },
    {
      "id": "create-target-group",
      "method": "POST",
      "path": "/target-groups",
      "summary": "대상 그룹 생성",
      "summaryKo": "대상 그룹 생성",
      "description": "로드 밸런서의 트래픽을 전달할 대상 그룹을 생성합니다.",
      "keywords": ["대상 그룹", "target group", "타겟 그룹"],
      "parameters": [],
      "requestBody": {
        "name": {"type": "string", "required": true, "description": "대상 그룹 이름"},
        "vpc_id": {"type": "string", "required": true, "description": "VPC ID"},
        "protocol": {"type": "string", "required": true, "description": "프로토콜 (HTTP/HTTPS/TCP)"},
        "port": {"type": "integer", "required": true, "description": "대상 포트"}
      },
      "responses": {
        "201": {"description": "대상 그룹 생성 완료"}
      }
    },
    {
      "id": "register-target",
      "method": "POST",
      "path": "/target-groups/:target_group_id/targets",
      "summary": "대상 등록",
      "summaryKo": "대상 그룹에 인스턴스 등록",
      "description": "대상 그룹에 인스턴스를 등록합니다.",
      "keywords": ["대상 등록", "target 등록", "인스턴스 등록"],
      "parameters": [
        {"name": "target_group_id", "in": "path", "type": "string", "required": true, "description": "대상 그룹 ID"}
      ],
      "requestBody": {
        "instance_id": {"type": "string", "required": true, "description": "인스턴스 ID"},
        "port": {"type": "integer", "required": true, "description": "대상 포트"}
      },
      "responses": {
        "201": {"description": "대상 등록 완료"}
      }
    }
  ]
}