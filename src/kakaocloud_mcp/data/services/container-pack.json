{
  "id": "container-pack",
  "name": "Container Pack",
  "nameKo": "컨테이너 팩 (Kubernetes Engine)",
  "description": "카카오클라우드의 관리형 Kubernetes 서비스. 클러스터 생성/관리, 노드 풀 관리 등을 제공합니다.",
  "baseUrl": "https://container-pack.kr-central-2.kakaocloud.com",
  "basePath": "/api/v1",
  "keywords": ["kubernetes", "k8s", "컨테이너", "container", "클러스터", "cluster", "노드", "node", "pod"],
  "dependencies": ["bns-vpc"],
  "endpoints": [
    {
      "id": "create-cluster",
      "method": "POST",
      "path": "/clusters",
      "summary": "Kubernetes 클러스터 생성",
      "summaryKo": "Kubernetes 클러스터 생성",
      "keywords": ["클러스터 생성", "k8s 생성", "create cluster", "kubernetes 생성"],
      "parameters": [],
      "requestBody": {
        "name": {"type": "string", "required": true, "description": "클러스터 이름"},
        "kubernetes_version": {"type": "string", "required": true, "description": "Kubernetes 버전"},
        "vpc_id": {"type": "string", "required": true, "description": "VPC ID"},
        "subnet_ids": {"type": "array", "required": true, "description": "서브넷 ID 배열"}
      },
      "responses": {
        "201": {"description": "클러스터 생성 요청 수락"}
      }
    },
    {
      "id": "list-clusters",
      "method": "GET",
      "path": "/clusters",
      "summary": "클러스터 목록 조회",
      "summaryKo": "클러스터 목록 조회",
      "keywords": ["클러스터 목록", "list clusters"],
      "parameters": [],
      "requestBody": null,
      "responses": {
        "200": {"description": "클러스터 목록 반환"}
      }
    },
    {
      "id": "get-cluster",
      "method": "GET",
      "path": "/clusters/:cluster_id",
      "summary": "클러스터 상세 조회",
      "summaryKo": "클러스터 상세 조회",
      "keywords": ["클러스터 상세", "클러스터 조회"],
      "parameters": [
        {"name": "cluster_id", "in": "path", "type": "string", "required": true, "description": "클러스터 ID"}
      ],
      "requestBody": null,
      "responses": {
        "200": {"description": "클러스터 상세 정보 반환"}
      }
    },
    {
      "id": "delete-cluster",
      "method": "DELETE",
      "path": "/clusters/:cluster_id",
      "summary": "클러스터 삭제",
      "summaryKo": "클러스터 삭제",
      "keywords": ["클러스터 삭제", "delete cluster"],
      "parameters": [
        {"name": "cluster_id", "in": "path", "type": "string", "required": true, "description": "클러스터 ID"}
      ],
      "requestBody": null,
      "responses": {
        "204": {"description": "클러스터 삭제 완료"}
      }
    },
    {
      "id": "create-node-pool",
      "method": "POST",
      "path": "/clusters/:cluster_id/node-pools",
      "summary": "노드 풀 생성",
      "summaryKo": "노드 풀 생성",
      "description": "클러스터에 워커 노드 풀을 추가합니다.",
      "keywords": ["노드 풀 생성", "node pool", "워커 노드"],
      "parameters": [
        {"name": "cluster_id", "in": "path", "type": "string", "required": true, "description": "클러스터 ID"}
      ],
      "requestBody": {
        "name": {"type": "string", "required": true, "description": "노드 풀 이름"},
        "flavor": {"type": "string", "required": true, "description": "노드 인스턴스 타입"},
        "node_count": {"type": "integer", "required": true, "description": "노드 수"},
        "subnet_id": {"type": "string", "required": true, "description": "서브넷 ID"}
      },
      "responses": {
        "201": {"description": "노드 풀 생성 완료"}
      }
    },
    {
      "id": "list-node-pools",
      "method": "GET",
      "path": "/clusters/:cluster_id/node-pools",
      "summary": "노드 풀 목록 조회",
      "summaryKo": "노드 풀 목록 조회",
      "keywords": ["노드 풀 목록", "list node pools"],
      "parameters": [
        {"name": "cluster_id", "in": "path", "type": "string", "required": true, "description": "클러스터 ID"}
      ],
      "requestBody": null,
      "responses": {
        "200": {"description": "노드 풀 목록 반환"}
      }
    },
    {
      "id": "get-kubeconfig",
      "method": "GET",
      "path": "/clusters/:cluster_name/kubeconfig",
      "summary": "Kubeconfig 조회",
      "summaryKo": "Kubeconfig 다운로드",
      "keywords": ["kubeconfig", "kubectl 설정", "클러스터 접속"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"}
      ],
      "requestBody": null,
      "responses": {"200": {"description": "Kubeconfig YAML 반환"}}
    },
    {
      "id": "update-cluster",
      "method": "PUT",
      "path": "/clusters/:cluster_name",
      "summary": "클러스터 수정",
      "summaryKo": "클러스터 설명 수정",
      "keywords": ["클러스터 수정", "update cluster"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"}
      ],
      "requestBody": {"description": {"type": "string", "required": false, "description": "클러스터 설명"}},
      "responses": {"202": {"description": "클러스터 수정 요청 수락"}}
    },
    {
      "id": "upgrade-cluster",
      "method": "POST",
      "path": "/clusters/:cluster_name/upgrade",
      "summary": "클러스터 버전 업그레이드",
      "summaryKo": "Kubernetes 버전 업그레이드",
      "keywords": ["클러스터 업그레이드", "k8s 업그레이드", "upgrade cluster", "버전 업그레이드"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"}
      ],
      "requestBody": null,
      "responses": {"202": {"description": "업그레이드 요청 수락"}}
    },
    {
      "id": "list-upgradable-versions",
      "method": "GET",
      "path": "/clusters/:cluster_name/upgrade",
      "summary": "업그레이드 가능 버전 조회",
      "summaryKo": "업그레이드 가능한 Kubernetes 버전 조회",
      "keywords": ["업그레이드 가능 버전", "k8s 버전"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"}
      ],
      "requestBody": null,
      "responses": {"200": {"description": "업그레이드 가능 버전 목록 반환"}}
    },
    {
      "id": "list-nodes",
      "method": "GET",
      "path": "/clusters/:cluster_name/nodes",
      "summary": "클러스터 노드 목록 조회",
      "summaryKo": "클러스터 내 모든 노드 목록 조회",
      "keywords": ["노드 목록", "list nodes", "워커 노드"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"}
      ],
      "requestBody": null,
      "responses": {"200": {"description": "노드 목록 반환"}}
    },
    {
      "id": "get-node-detail",
      "method": "GET",
      "path": "/clusters/:cluster_name/nodes/:node_name/details",
      "summary": "노드 상세 조회",
      "summaryKo": "노드 상세 정보 조회 (스펙, 상태, 이벤트, Pod)",
      "keywords": ["노드 상세", "node detail"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"},
        {"name": "node_name", "in": "path", "type": "string", "required": true, "description": "노드 이름"}
      ],
      "requestBody": null,
      "responses": {"200": {"description": "노드 상세 정보 반환"}}
    },
    {
      "id": "update-node-pool",
      "method": "PUT",
      "path": "/clusters/:cluster_name/node-pools/:node_pool_name",
      "summary": "노드 풀 수정",
      "summaryKo": "노드 풀 수정 (노드 수, 보안 그룹, 설명)",
      "keywords": ["노드 풀 수정", "update node pool", "노드 수 변경"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"},
        {"name": "node_pool_name", "in": "path", "type": "string", "required": true, "description": "노드 풀 이름"}
      ],
      "requestBody": {
        "node_count": {"type": "integer", "required": false, "description": "노드 수"},
        "description": {"type": "string", "required": false, "description": "설명"}
      },
      "responses": {"202": {"description": "노드 풀 수정 요청 수락"}}
    },
    {
      "id": "set-autoscaling",
      "method": "PUT",
      "path": "/clusters/:cluster_name/node-pools/:node_pool_name/autoscaling",
      "summary": "오토스케일링 설정",
      "summaryKo": "노드 풀 오토스케일링 설정",
      "keywords": ["오토스케일링", "autoscaling", "자동 확장", "auto scaling"],
      "parameters": [
        {"name": "cluster_name", "in": "path", "type": "string", "required": true, "description": "클러스터 이름"},
        {"name": "node_pool_name", "in": "path", "type": "string", "required": true, "description": "노드 풀 이름"}
      ],
      "requestBody": null,
      "responses": {"202": {"description": "오토스케일링 설정 요청 수락"}}
    },
    {
      "id": "list-k8s-versions",
      "method": "GET",
      "path": "/versions",
      "summary": "Kubernetes 버전 목록",
      "summaryKo": "사용 가능한 Kubernetes 버전 조회",
      "keywords": ["k8s 버전", "kubernetes version", "지원 버전"],
      "parameters": [],
      "requestBody": null,
      "responses": {"200": {"description": "Kubernetes 버전 목록 반환"}}
    },
    {
      "id": "create-service-agent",
      "method": "POST",
      "path": "/service-agents",
      "summary": "서비스 에이전트 생성",
      "summaryKo": "K8s Engine 서비스 에이전트 생성 (필수 사전 작업)",
      "keywords": ["서비스 에이전트", "service agent"],
      "parameters": [],
      "requestBody": null,
      "responses": {"200": {"description": "서비스 에이전트 생성 완료"}}
    }
  ]
}